import time
import board
import busio
import adafruit_mpr121
from pygame import mixer
import os
import threading

# ====================== [1. 오디오 설정 - 노이즈 해결 핵심] ======================
os.environ["SDL_AUDIODRIVER"] = "alsa"
os.environ["AUDIODEV"] = "hw:2,0"        # ← aplay -l 로 확인 후 hw:0,0 / hw:1,0 / hw:2,0 중 맞는 걸로 변경

# WAV 파일 대부분 44100Hz이므로 정확히 맞춤 + 버퍼 크게
mixer.pre_init(frequency=44100, size=-16, channels=2, buffer=1024)
mixer.init()
mixer.set_num_channels(16)   # 여유 있게 16채널

print("🎵 오디오 초기화 완료 (노이즈 방지 설정 적용)")

SOUND_PATH = "/home/noisezero/noise_zero/piano/"

full_notes = [
    "AS1", "B1", "C2", "CS2", "D2", "DS2", "E2", "F2", "FS2", "G2", "GS2", "A2",
    "AS2", "B2", "C3", "CS3", "D3", "DS3", "E3", "F3", "FS3", "G3", "GS3", "A3",
    "AS3", "B3", "C4", "CS4", "D4", "DS4", "E4", "F4", "FS4", "G4", "GS4", "A4",
    "AS4", "B4", "C5", "CS5", "D5", "DS5"
]

# ====================== [2. 음원 로드 + 채널 분리] ======================
piano_sounds = []
for name in full_notes:
    path = os.path.join(SOUND_PATH, f"{name}.wav")
    if os.path.exists(path):
        try:
            sound = mixer.Sound(path)
            sound.set_volume(0.8)
            piano_sounds.append(sound)
            print(f"Loaded: {name}.wav")
        except Exception as e:
            print(f"Error loading {name}.wav : {e}")
            piano_sounds.append(None)
    else:
        print(f"Missing: {path}")
        piano_sounds.append(None)

# 패드별 독립 채널 (노이즈 + 중복 재생 방지)
channels = [mixer.Channel(i) for i in range(12)]

# ====================== [3. 변수] ======================
base_index = 26          # C4 근처부터 시작 (원하는 대로 조정)
volume = 0.8
loop_state = "IDLE"
loop_data = []
is_looping = False
loop_start_time = 0
last_touch_time = 0

# ====================== [4. 함수] ======================
def adjust_volume(delta):
    global volume
    volume = max(0.1, min(1.0, volume + delta))
    for sound in piano_sounds:
        if sound:
            sound.set_volume(volume)
    print(f"Volume: {int(volume*100)}%")

def play_note(pad_idx, record=True):
    global loop_data, loop_start_time
    target_idx = base_index + pad_idx
    if target_idx >= len(piano_sounds) or not piano_sounds[target_idx]:
        return

    ch = channels[pad_idx]
    if ch.get_busy():
        ch.stop()                     # 이전 소리 즉시 끊기

    print(f"▶ Playing: {full_notes[target_idx]}")
    ch.play(piano_sounds[target_idx])

    if loop_state == "RECORDING" and record:
        loop_data.append((time.time() - loop_start_time, target_idx))

def handle_loop_logic():
    global loop_state, last_touch_time, loop_data, loop_start_time, is_looping
    now = time.time()

    if now - last_touch_time < 0.35:   # 연속 터치 = 리셋
        is_looping = False
        loop_data = []
        loop_state = "IDLE"
        print("🔄 LOOP RESET")
        return

    last_touch_time = now

    if loop_state == "IDLE":
        loop_state = "RECORDING"
        loop_data = []
        loop_start_time = time.time()
        print("⏺ RECORDING...")
    elif loop_state == "RECORDING":
        loop_state = "PLAYING"
        is_looping = True
        threading.Thread(target=loop_player, daemon=True).start()
        print("▶ PLAYING LOOP")
    elif loop_state == "PLAYING":
        is_looping = False
        loop_state = "IDLE"
        print("⏹ LOOP STOPPED")

def loop_player():
    global is_looping
    while is_looping:
        start = time.time()
        for ts, idx in loop_data:
            while time.time() - start < ts:
                if not is_looping:
                    return
                time.sleep(0.001)
            if idx < len(piano_sounds) and piano_sounds[idx]:
                channels[0].play(piano_sounds[idx])   # 루프는 채널 0 사용
        time.sleep(0.02)

# ====================== [5. 메인 루프] ======================
print("=== Launchpad 시작 ===")

i2c0 = busio.I2C(board.D1, board.D0)
i2c1 = busio.I2C(board.SCL, board.SDA)

mpr_piano = adafruit_mpr121.MPR121(i2c0, address=0x5A)
mpr_ctrl = adafruit_mpr121.MPR121(i2c1, address=0x5A)

try:
    while True:
        # ==================== 컨트롤 패드 ====================
        if mpr_ctrl[0].value:   # Oct Up
            base_index = min(len(piano_sounds)-12, base_index + 12)
            print(f"Oct UP → {base_index}")
            while mpr_ctrl[0].value: time.sleep(0.01)

        if mpr_ctrl[1].value:   # Oct Down
            base_index = max(0, base_index - 12)
            print(f"Oct DOWN → {base_index}")
            while mpr_ctrl[1].value: time.sleep(0.01)

        if mpr_ctrl[2].value:   # Loop
            handle_loop_logic()
            while mpr_ctrl[2].value: time.sleep(0.01)

        if mpr_ctrl[3].value:   # Vol Up
            adjust_volume(0.05)
            while mpr_ctrl[3].value: time.sleep(0.01)

        if mpr_ctrl[4].value:   # Vol Down
            adjust_volume(-0.05)
            while mpr_ctrl[4].value: time.sleep(0.01)

        # ==================== 연주 패드 ====================
        for i in range(12):
            if mpr_piano[i].value:
                play_note(i)
                # debouncing
                while mpr_piano[i].value:
                    time.sleep(0.008)

        time.sleep(0.005)

except KeyboardInterrupt:
    mixer.quit()
    print("🚪 종료!")
