python3 -c "
import jack
import numpy as np

client = jack.Client('TEST')
inport = client.inports.register('input_1')

@client.set_process_callback
def process(frames):
    data = inport.get_array()
    level = np.max(np.abs(data))
    if level > 0.01:
        print(f'레벨: {level:.3f}')

with client:
    client.connect('system:capture_1', 'TEST:input_1')
    print('휴대폰으로 300Hz 재생해보세요...')
    input()
"
