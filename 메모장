import sounddevice as sd
import numpy as np

SAMPLE_RATE = 48000
BLOCK_SIZE  = 512
GAIN        = 8.0
DEVICE      = 1

def callback(indata, outdata, frames, time, status):
    if status:
        print(status)
    outdata[:] = np.clip(indata * GAIN, -1.0, 1.0)

print("루프백 시작 - Ctrl+C 로 종료")
with sd.Stream(device=(DEVICE, DEVICE),
               samplerate=SAMPLE_RATE,
               blocksize=BLOCK_SIZE,
               dtype='float32',
               channels=2,
               callback=callback):
    sd.sleep(30000)
