import jack
import numpy as np
import time

client = jack.Client('ANC')
inport  = client.inports.register('input_1')
outport = client.outports.register('output_1')

GAIN = 10.0

@client.set_process_callback
def process(frames):
    data = inport.get_array().astype(np.float32)
    out  = np.clip(-data * GAIN, -1.0, 1.0)
    outport.get_buffer()[:] = out.tobytes()

client.activate()

try:
    client.connect('system:capture_1', 'ANC:input_1')
except:
    pass

try:
    client.connect('ANC:output_1', 'system:playback_1')
except:
    pass

print('ANC 시작 - Ctrl+C 종료')

try:
    while True:
        time.sleep(0.1)
except KeyboardInterrupt:
    print('종료')
    client.deactivate()
    client.close()
