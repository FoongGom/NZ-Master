import sounddevice as sd
import numpy as np

stream = sd.Stream(device=(1, 1),
                   samplerate=48000,
                   blocksize=64,
                   dtype='float32',
                   channels=2,
                   latency='low')
stream.start()
print(f"입력 레이턴시: {stream.latency[0]*1000:.2f}ms")
print(f"출력 레이턴시: {stream.latency[1]*1000:.2f}ms")
stream.stop()
stream.close()
