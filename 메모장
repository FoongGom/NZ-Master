import sounddevice as sd
import numpy as np

SAMPLE_RATE = 48000
BLOCK_SIZE  = 512
DEVICE      = 1

def callback(indata, outdata, frames, time, status):
    if status:
        print(status)
    
    # 입력 신호 크기 측정
    input_level = np.max(np.abs(indata))
    
    # 입력이 있을 때만 출력 (게인 자동 조절)
    if input_level > 0.001:
        # 입력과 같은 크기로 반전 출력
        outdata[:] = -indata
    else:
        outdata[:] = 0

print("ANC 시작 - Ctrl+C 로 종료")
with sd.Stream(device=(DEVICE, DEVICE),
               samplerate=SAMPLE_RATE,
               blocksize=BLOCK_SIZE,
               dtype='float32',
               channels=2,
               callback=callback):
    sd.sleep(30000)
