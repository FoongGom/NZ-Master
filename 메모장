import sounddevice as sd
import numpy as np

SAMPLE_RATE = 48000
BLOCK_SIZE = 512
GAIN = 8.0  # 볼륨 높이는 값

def callback(indata, outdata, frames, time, status):
    if status:
        print(status)
    # 그대로 출력 (루프백 테스트)
    outdata[:] = np.clip(indata * GAIN, -1.0, 1.0)

print("장치 목록:")
print(sd.query_devices())
